})

output$stu.plot2 = renderPlot({
  df <- student_session_compare()

  ggplot(df, aes(x = SESSION_NUMBER)) +
    geom_line(aes(y = QUIZ_SCORE, color = "Student"), linewidth = 1) +
    geom_point(aes(y = QUIZ_SCORE, color = "Student"), size = 2) +
    geom_line(aes(y = class_quiz, color = "Class average"), linewidth = 1, linetype = "dashed") +
